*?PageSize: "
save
	currentpagedevice /PageSize get aload pop
	2 copy gt {exch} if 
	(Unknown) 
	<<
    [595 842]  (A4)
    [420 595]  (A5.Transverse)
    [297 420]  (A6)
    [516 729]  (B5.Transverse)
    [363 516]  (B6)
    [612 792]  (Letter)
    [612 936]  (8.5x13in)
    [612 1008]  (Legal)
    [522 756]  (Executive)
    [297 684]  (Env10)
    [312 624]  (EnvDL)
    [323 459]  (EnvC6)
  >>
	{ exch aload pop 4 index sub abs 5 le exch 
	5 index sub abs 5 le and 
	{exch pop exit} {pop} ifelse
	} bind forall
	= flush pop pop
restore 
"
*End
